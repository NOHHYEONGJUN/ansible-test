{# OpenTelemetry Collector — Amazon Linux: metrics + systemd journal → Loki (OTLP)

   Ubuntu용 filelog(/var/log/syslog) 대신 journald 수신기를 씁니다.
   otelcol 사용자는 플레이북에서 systemd-journal 보조 그룹이 필요합니다.

   Loki OTLP index label / service.instance.id 설명은 github/templates/config-with-loki.yaml.j2 와 동일합니다.
#}
extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
{# journald 를 otlp 다음에 두면 일부 환경에서 들여쓰기가 otlp.protocols 아래로 붙는 YAML 오해석이 나와 otlp에 invalid key journald 오류가 남 #}
{% if monitor_logs | bool %}
  journald: {}
{% endif %}
{% if monitor_metrics | bool %}
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem:
        exclude_mount_points:
          match_type: regexp
          mount_points:
            - /dev/.*
            - /proc/.*
            - /sys/.*
            - /run/.*
            - /var/lib/containers/.*
            - /var/lib/docker/.*
            - /run/containerd/.*
        exclude_fs_types:
          match_type: strict
          fs_types:
            - autofs
            - binfmt_misc
            - bpf
            - cgroup2
            - configfs
            - debugfs
            - devpts
            - devtmpfs
            - overlay
            - proc
            - sysfs
            - tmpfs

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]
{% endif %}
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

processors:
  resource:
    attributes:
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert
{% if monitor_logs | bool %}
      - key: service.name
        value: "amazon-linux-system"
        action: upsert
      - key: service.instance.id
        value: "{{ inventory_hostname }}"
        action: upsert
{% endif %}

{% if monitor_logs | bool %}
  # journald body 는 맵이라 Loki 에 JSON 덤프처럼 보임 → syslog 한 줄로 평탄화 (batch 앞에 두어 YAML/템플릿에서 batch 하위로 잘못 중첩되는 경우 방지)
  transform/journald_to_syslog_line:
    error_mode: ignore
    log_statements:
      - context: log
        statements:
          # 로그 줄 hostname: journald _HOSTNAME(보통 ip-10-x… 형·FQDN) 우선, 첫 "." 뒤 도메인 제거 → Ubuntu syslog 의 짧은 형태와 비슷하게
          # replace_pattern 은 set() 인자 안에 넣으면 OTTL 파서가 거부할 수 있어 cache 에 문자열을 올린 뒤 단독 문으로 치환
          - 'set(cache["line_host"], String(body["_HOSTNAME"])) where IsMap(body) and body["_HOSTNAME"] != nil'
          - 'set(cache["line_host"], String(resource.attributes["host.name"])) where IsMap(body) and body["_HOSTNAME"] == nil'
          - 'replace_pattern(cache["line_host"], "\\..*", "") where cache["line_host"] != nil and IsMatch(cache["line_host"], "\\.")'
          # OTTL 안의 ": " 가 YAML 에서 매핑으로 오해되므로 아래 set 문은 작은따옴표로 감쌈
          - 'set(body, Concat([String(time), " ", cache["line_host"], " ", String(body["SYSLOG_IDENTIFIER"]), ": ", String(body["MESSAGE"])], "")) where IsMap(body) and body["MESSAGE"] != nil and body["SYSLOG_IDENTIFIER"] != nil'
          - 'set(body, Concat([String(time), " ", cache["line_host"], " ", String(body["_COMM"]), ": ", String(body["MESSAGE"])], "")) where IsMap(body) and body["MESSAGE"] != nil and body["_COMM"] != nil'
          - 'set(body, Concat([String(time), " ", cache["line_host"], " ", String(body["UNIT"]), ": ", String(body["MESSAGE"])], "")) where IsMap(body) and body["MESSAGE"] != nil and body["UNIT"] != nil'
          - 'set(body, Concat([String(time), " ", cache["line_host"], " journal: ", String(body["MESSAGE"])], "")) where IsMap(body) and body["MESSAGE"] != nil'
{% endif %}

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic
{# prometheusremotewrite 다음에 두면 들여쓰기가 한 단계 깊게 해석되어 otlphttp 가 그 블록 안으로 들어가 endpoint 키 중복 YAML 오류가 남 #}
{% if monitor_logs | bool %}
  "otlphttp/loki":
    endpoint: "{{ otel_loki_endpoint | trim | regex_replace('/$', '') }}/otlp"
{% endif %}
{% if monitor_metrics | bool %}
  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true
{% endif %}

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888

  extensions: [health_check, zpages]

  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% elif monitor_logs | bool %}
    {# 메트릭 끄고 로그만 켠 경우에도 otlp 수신기는 파이프라인에 묶어야 함 #}
    metrics:
      receivers: [otlp]
      processors: [resource, batch]
      exporters: [debug]
{% endif %}
{% if monitor_logs | bool %}
    logs:
      receivers: [journald]
      processors: [resource, transform/journald_to_syslog_line, batch]
      exporters: ["otlphttp/loki"]
{% endif %}

{# OpenTelemetry Collector — Amazon Linux: metrics + systemd journal → Loki (OTLP)

   Ubuntu용 filelog(/var/log/syslog) 대신 journald 수신기를 씁니다.
   otelcol 사용자는 플레이북에서 systemd-journal 보조 그룹이 필요합니다.

   Loki OTLP index label / service.instance.id 설명은 github/templates/config-with-loki.yaml.j2 와 동일합니다.
#}
extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
{# journald 를 otlp 다음에 두면 일부 환경에서 들여쓰기가 otlp.protocols 아래로 붙는 YAML 오해석이 나와 otlp에 invalid key journald 오류가 남 #}
{% if monitor_logs | bool %}
  journald: {}
{% endif %}
{% if monitor_metrics | bool %}
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem:
        exclude_mount_points:
          match_type: regexp
          mount_points:
            - /dev/.*
            - /proc/.*
            - /sys/.*
            - /run/.*
            - /var/lib/containers/.*
            - /var/lib/docker/.*
            - /run/containerd/.*
        exclude_fs_types:
          match_type: strict
          fs_types:
            - autofs
            - binfmt_misc
            - bpf
            - cgroup2
            - configfs
            - debugfs
            - devpts
            - devtmpfs
            - overlay
            - proc
            - sysfs
            - tmpfs

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]
{% endif %}
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

processors:
  resource:
    attributes:
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert
{% if monitor_logs | bool %}
      - key: service.name
        value: "amazon-linux-system"
        action: upsert
      - key: service.instance.id
        value: "{{ inventory_hostname }}"
        action: upsert
{% endif %}

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic

{% if monitor_metrics | bool %}
  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true
{% endif %}

{% if monitor_logs | bool %}
  {# Loki OTLP HTTP — VM(수집기)에서 이 URL로 나갈 수 있어야 함. HTTPS+자체서명이면 extra_vars 로 템플릿 확장 또는 Loki 앞단 프록시 TLS 종료 권장 #}
  "otlphttp/loki":
    endpoint: "{{ otel_loki_endpoint | trim | regex_replace('/$', '') }}/otlp"
    retry_on_failure:
      enabled: true
    sending_queue:
      enabled: true
      num_consumers: 4
      queue_size: 100
{% endif %}

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888

  extensions: [health_check, zpages]

  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% elif monitor_logs | bool %}
    {# 메트릭 끄고 로그만 켠 경우에도 otlp 수신기는 파이프라인에 묶어야 함 #}
    metrics:
      receivers: [otlp]
      processors: [resource, batch]
      exporters: [debug]
{% endif %}
{% if monitor_logs | bool %}
    logs:
      receivers: [journald]
      processors: [resource, batch]
      exporters: ["otlphttp/loki"]
{% endif %}

extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
{% if monitor_metrics | bool %}
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem:
        exclude_mount_points:
          match_type: regexp
          mount_points:
            - /dev/.*
            - /proc/.*
            - /sys/.*
            - /run/.*
            - /var/lib/containers/.*
            - /var/lib/docker/.*
            - /run/containerd/.*
        exclude_fs_types:
          match_type: strict
          fs_types:
            - autofs
            - binfmt_misc
            - bpf
            - cgroup2
            - configfs
            - debugfs
            - devpts
            - devtmpfs
            - overlay
            - proc
            - sysfs
            - tmpfs

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]
{% endif %}

  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

processors:
  resource:
    attributes:
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic

{% if monitor_metrics | bool %}
  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true
{% endif %}

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888

  extensions: [health_check, zpages]

  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% else %}
    metrics:
      receivers: [otlp]
      processors: [resource, batch]
      exporters: [debug]
{% endif %}

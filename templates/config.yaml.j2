extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem: {}

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]

  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

processors:
  resource:
    attributes:
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic

  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888

  extensions: [health_check, zpages]

  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% endif %}

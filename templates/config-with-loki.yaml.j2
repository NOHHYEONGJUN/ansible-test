{# OpenTelemetry Collector — metrics + logs (Loki via OTLP ingestion)

   중요:
   - Grafana Loki의 OTLP ingestion은 "어떤 resource attribute를 index label로 승격할지"를 Loki 서버 설정으로 결정합니다.
   - 기본값으로 service.name 등 일부만 index label이 되며, host.name(→host_name)은 보통 structured metadata로 저장되어
     Grafana Explore의 Label filters 드롭다운(/labels)에는 안 보일 수 있습니다.

   그래서 Collector 쪽에서는 host.name을 유지하면서, 기본 index label에 포함되는 service.instance.id에도 동일 값을 넣어
   Grafana에서 'Label filters → service_instance_id=<vm>'로 필터링 가능하게 합니다.
#}
extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
{% if monitor_metrics | bool %}
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem: {}

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]
{% endif %}

  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

{% if monitor_logs | bool %}
  filelog:
    include: [/var/log/syslog, /var/log/auth.log]
    start_at: end
    operators:
      - type: regex_parser
        regex: '^(?P<time>\S+)\s+(?P<host>\S+)\s+(?P<process>[^:\[\s]+)(?:\[(?P<pid>\d+)\])?:\s+(?P<msg>.*)$'
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: '2006-01-02T15:04:05.999999-07:00'
{% endif %}

processors:
  resource:
    attributes:
      # host.name은 메트릭/로그 공통 식별자(대시보드 변수)로 유지합니다.
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert
{% if monitor_logs | bool %}
      - key: service.name
        value: "ubuntu-system"
        action: upsert
      # Loki OTLP ingestion 기본 index label 목록에 포함되는 값.
      # 결과 라벨: service_instance_id={{ inventory_hostname }}
      - key: service.instance.id
        value: "{{ inventory_hostname }}"
        action: upsert
{% endif %}

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic

{% if monitor_metrics | bool %}
  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true
{% endif %}

{% if monitor_logs | bool %}
  # Grafana Loki 권장: OTLP ingestion (/otlp). 리소스 속성 → 라벨 승격은 loki.resource.labels 로 제어.
  "otlphttp/loki":
    endpoint: "{{ otel_loki_endpoint | trim | regex_replace('/$', '') }}/otlp"
{% endif %}

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888

  extensions: [health_check, zpages]

  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% endif %}
{% if monitor_logs | bool %}
    logs:
      receivers: [filelog]
      processors: [resource, batch]
      exporters: ["otlphttp/loki"]
{% endif %}

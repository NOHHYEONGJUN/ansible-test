{# OpenTelemetry Collector — metrics + logs
   Loki 드롭다운 메뉴 활성화를 위해 점(.) 대신 언더바(_) 라벨 사용
#}
extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
{% if monitor_metrics | bool %}
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem: {}

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]
{% endif %}

  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

{% if monitor_logs | bool %}
  filelog:
    include: [/var/log/syslog, /var/log/auth.log]
    start_at: end
    operators:
      - type: regex_parser
        regex: '^(?P<time>\S+)\s+(?P<host>\S+)\s+(?P<process>[^:\[\s]+)(?:\[(?P<pid>\d+)\])?:\s+(?P<msg>.*)$'
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: '2006-01-02T15:04:05.999999-07:00'
{% endif %}

processors:
  resource:
    attributes:
      # 1. host.name (OTLP 표준 - 메타데이터로 저장됨)
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert
      # 2. host_name (Loki가 인덱스 라벨로 인식하도록 언더바 사용)
      - key: host_name
        value: "{{ inventory_hostname }}"
        action: upsert
      # 3. instance (프로메테우스와 완벽한 일치를 위해 추가)
      - key: instance
        value: "{{ inventory_hostname }}"
        action: upsert
{% if monitor_logs | bool %}
      - key: service.name
        value: "ubuntu-system"
        action: upsert
{% endif %}

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic

{% if monitor_metrics | bool %}
  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true
{% endif %}

{% if monitor_logs | bool %}
  # 가장 안정적인 otlphttp 사용 (Loki 3.0 최적화)
  "otlphttp/loki":
    endpoint: "{{ otel_loki_endpoint | trim | regex_replace('/$', '') }}/otlp"
{% endif %}

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888
  extensions: [health_check, zpages]
  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% endif %}
{% if monitor_logs | bool %}
    logs:
      receivers: [filelog]
      processors: [resource, batch]
      exporters: ["otlphttp/loki"]
{% endif %}

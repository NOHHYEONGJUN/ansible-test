{# OpenTelemetry Collector — metrics + logs (Loki Dedicated Exporter)
   resource_to_labels: true 설정을 통해 Grafana 드롭다운 메뉴 활성화
#}
extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
{% if monitor_metrics | bool %}
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem: {}

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]
{% endif %}

  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

{% if monitor_logs | bool %}
  filelog:
    include: [/var/log/syslog, /var/log/auth.log]
    start_at: end
    operators:
      - type: regex_parser
        regex: '^(?P<time>\S+)\s+(?P<host>\S+)\s+(?P<process>[^:\[\s]+)(?:\[(?P<pid>\d+)\])?:\s+(?P<msg>.*)$'
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: '2006-01-02T15:04:05.999999-07:00'
{% endif %}

processors:
  resource:
    attributes:
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert
{% if monitor_logs | bool %}
      - key: service.name
        value: "ubuntu-system"
        action: upsert
{% endif %}

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic

{% if monitor_metrics | bool %}
  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true
{% endif %}

{% if monitor_logs | bool %}
  # 수정 포인트: labels 블록 제거 및 resource_to_labels 추가
  loki:
    endpoint: "{{ otel_loki_endpoint | trim | regex_replace('/$', '') }}/loki/api/v1/push"
    resource_to_labels: true 
{% endif %}

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888

  extensions: [health_check, zpages]

  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% endif %}
{% if monitor_logs | bool %}
    logs:
      receivers: [filelog]
      processors: [resource, batch]
      exporters: [loki] 
{% endif %}

{# OpenTelemetry Collector — metrics + logs (Loki)
   0.102.x 버전에서는 별도 설정 없이 resource 속성을 자동으로 라벨링합니다.
#}
extensions:
  health_check: {}
  zpages:
    endpoint: 0.0.0.0:55679

receivers:
{% if monitor_metrics | bool %}
  hostmetrics:
    collection_interval: 10s
    scrapers:
      cpu: {}
      memory: {}
      load: {}
      disk: {}
      network: {}
      filesystem: {}

  prometheus:
    config:
      scrape_configs:
        - job_name: "otel-collector"
          scrape_interval: 10s
          static_configs:
            - targets: ["0.0.0.0:8888"]
{% endif %}

  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

{% if monitor_logs | bool %}
  filelog:
    include: [/var/log/syslog, /var/log/auth.log]
    start_at: end
    operators:
      - type: regex_parser
        regex: '^(?P<time>\S+)\s+(?P<host>\S+)\s+(?P<process>[^:\[\s]+)(?:\[(?P<pid>\d+)\])?:\s+(?P<msg>.*)$'
        timestamp:
          parse_from: attributes.time
          layout_type: gotime
          layout: '2006-01-02T15:04:05.999999-07:00'
{% endif %}

processors:
  resource:
    attributes:
      # host.name / service.name 은 Loki에서 host_name / service_name 으로 변환될 수 있습니다.
      # 다만 OTLP→Loki 에서는 어떤 리소스 속성을 "인덱스 라벨"로 승격할지 힌트가 필요할 수 있어
      # loki.resource.labels 로 명시합니다(그래야 Grafana Explore의 Label filters에 host_name이 나타납니다).
      - key: host.name
        value: "{{ inventory_hostname }}"
        action: upsert
{% if monitor_logs | bool %}
      - key: service.name
        value: "ubuntu-system"
        action: upsert
      - key: loki.resource.labels
        value: "host.name,service.name"
        action: upsert
{% endif %}

  batch:
    send_batch_size: 1000
    timeout: 10s

exporters:
  debug:
    verbosity: basic

{% if monitor_metrics | bool %}
  prometheusremotewrite:
    endpoint: "{{ otel_prom_rw_endpoint }}"
    timeout: 30s
    headers:
      X-Scope-OrgID: "{{ otel_prom_rw_org_id }}"
    resource_to_telemetry_conversion:
      enabled: true
{% endif %}

{% if monitor_logs | bool %}
  # Grafana Loki 권장: OTLP ingestion (/otlp). 리소스 속성 → 라벨 승격은 loki.resource.labels 로 제어.
  "otlphttp/loki":
    endpoint: "{{ otel_loki_endpoint | trim | regex_replace('/$', '') }}/otlp"
{% endif %}

service:
  telemetry:
    metrics:
      address: 0.0.0.0:8888

  extensions: [health_check, zpages]

  pipelines:
{% if monitor_metrics | bool %}
    metrics:
      receivers: [hostmetrics, prometheus, otlp]
      processors: [resource, batch]
      exporters: [debug, prometheusremotewrite]
{% endif %}
{% if monitor_logs | bool %}
    logs:
      receivers: [filelog]
      processors: [resource, batch]
      exporters: ["otlphttp/loki"]
{% endif %}
